sets:
  - package: mypackage
    selector:
      files:
        - .configs/**
        - docs/**
      exclude:
        - .configs/database.config.json
    output:
      path: output
      gitignore: true

  - package: mypackage
    selector:
      files:
        - .configs/database.config.json
    output:
      path: output
      managed: false
      mutable: true
