defaultPresets:
  - basic
postExtractCmd:
  - node
  - myPostExtract.js
sets:
  - package: mypackage
    upgrade: false
    selector:
      files:
        - docs/**
        - data/**
      contentRegexes:
        - .*
    output:
      path: output
      force: false
      keepExisting: true
      gitignore: true
      managed: true
      dryRun: false
      symlinks:
        - source: data/**
          target: data-symlink/
      contentReplacements:
        - files: docs/**
          match: exampleTODOTESTCHECKLATER
          replace: sample
    presets:
      - basic

  - package: eslint@8
    selector:
      files:
        - conf/globals.js
    output:
      path: output/eslint
      managed: false
    presets:
      - extra

  - package: mypackage
    selector:
      presets:
        - eslint
    output:
      path: output/nested-eslint
    presets:
      - nested-eslint
